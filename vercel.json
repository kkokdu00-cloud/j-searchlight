{
  "version": 2,
  "routes": [
    { "src": "/api/blob-upload",               "dest": "/api/blob-upload.js" },
    { "src": "/api/drugs/search",              "dest": "/api/drugs/search.js" },
    { "src": "/api/drugs/manual",              "dest": "/api/drugs/manual.js" },
    { "src": "/api/drugs/ingredients/([^/]+)", "dest": "/api/drugs/ingredients/[ingdCd].js?ingdCd=$1" },
    { "src": "/api/commission(.*)",            "dest": "/api/commission/index.js" },
    { "src": "/api/ocr",                       "dest": "/api/ocr.js" },
    { "src": "/api/sessions(.*)",              "dest": "/api/sessions.js" },
    { "src": "/api/clients(.*)",               "dest": "/api/clients.js" },
    { "src": "/api/pharma(.*)",                "dest": "/api/clients.js" },
    { "src": "/api/verify-codes",              "dest": "/api/verify-codes.js" },
    { "src": "/api/auth(.*)",                  "dest": "/api/auth.js" },
    { "src": "/api/sep(.*)",                   "dest": "/api/clients.js" },
    { "src": "/api/cso/core(.*)",              "dest": "/api/cso/core.js" },
    { "src": "/api/cso/data(.*)",              "dest": "/api/cso/data.js" },
    { "src": "/",                              "dest": "/index.html" },
    { "src": "/(.*)",                          "dest": "/$1" }
  ]
}
